{
  "name": "TripoSR Image to 3D",
  "description": "Generate 3D models from a single image using TripoSR. Outputs GLB format for use in games, AR/VR, and 3D printing.",
  "category": "3d",
  "tags": ["3d", "triposr", "mesh", "glb", "image-to-3d"],
  "model_requirements": ["triposr_model.safetensors"],
  "vram_requirement_gb": 16,
  "input_schema": {
    "type": "object",
    "properties": {
      "image": {
        "type": "string",
        "format": "uri",
        "description": "Input image for 3D reconstruction"
      },
      "remove_background": {
        "type": "boolean",
        "default": true,
        "description": "Remove background before 3D conversion"
      },
      "foreground_ratio": {
        "type": "number",
        "default": 0.85,
        "minimum": 0.5,
        "maximum": 1.0,
        "description": "Foreground object ratio in frame"
      },
      "mesh_resolution": {
        "type": "integer",
        "default": 256,
        "minimum": 128,
        "maximum": 512,
        "description": "Output mesh resolution"
      }
    },
    "required": ["image"]
  },
  "workflow": {
    "last_node_id": 6,
    "last_link_id": 5,
    "nodes": [
      {
        "id": 1,
        "type": "LoadImage",
        "pos": [50, 100],
        "size": [300, 300],
        "inputs": [],
        "outputs": [
          {"name": "IMAGE", "type": "IMAGE", "links": [1]},
          {"name": "MASK", "type": "MASK", "links": null}
        ],
        "widgets_values": ["{{image}}"]
      },
      {
        "id": 2,
        "type": "RMBG",
        "pos": [400, 100],
        "size": [200, 100],
        "inputs": [
          {"name": "image", "type": "IMAGE", "link": 1}
        ],
        "outputs": [
          {"name": "IMAGE", "type": "IMAGE", "links": [2]},
          {"name": "MASK", "type": "MASK", "links": null}
        ],
        "widgets_values": []
      },
      {
        "id": 3,
        "type": "TripoSRModelLoader",
        "pos": [50, 350],
        "size": [300, 80],
        "inputs": [],
        "outputs": [
          {"name": "TRIPOSR_MODEL", "type": "TRIPOSR_MODEL", "links": [3]}
        ],
        "widgets_values": []
      },
      {
        "id": 4,
        "type": "TripoSRSampler",
        "pos": [650, 150],
        "size": [300, 200],
        "inputs": [
          {"name": "model", "type": "TRIPOSR_MODEL", "link": 3},
          {"name": "image", "type": "IMAGE", "link": 2}
        ],
        "outputs": [
          {"name": "MESH", "type": "MESH", "links": [4]}
        ],
        "widgets_values": ["{{foreground_ratio}}", "{{mesh_resolution}}", 1]
      },
      {
        "id": 5,
        "type": "SaveGLB",
        "pos": [1000, 150],
        "size": [300, 150],
        "inputs": [
          {"name": "mesh", "type": "MESH", "link": 4}
        ],
        "outputs": [],
        "widgets_values": ["triposr_3d"]
      }
    ],
    "links": [
      [1, 1, 0, 2, 0, "IMAGE"],
      [2, 2, 0, 4, 1, "IMAGE"],
      [3, 3, 0, 4, 0, "TRIPOSR_MODEL"],
      [4, 4, 0, 5, 0, "MESH"]
    ],
    "groups": [],
    "config": {},
    "extra": {},
    "version": 0.4
  }
}
