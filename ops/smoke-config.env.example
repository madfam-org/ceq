# CEQ production smoke configuration
#
# Copy to smoke-config.env (gitignored) and fill credentials:
#   cp ops/smoke-config.env.example ops/smoke-config.env
#   source ops/smoke-config.env
#
# Obtain CEQ_AUTH_TOKEN:
#   1. Log in to https://app.ceq.lol as admin@madfam.io
#   2. DevTools → Application → Cookies → ceq_access_token (httpOnly)
#      OR call GET /api/auth/session and copy access_token from JSON
#   3. Verify aud=ceq-api in JWT payload (jwt.io)

export CEQ_API_URL="${CEQ_API_URL:-https://api.ceq.lol}"
export CEQ_APP_URL="${CEQ_APP_URL:-https://app.ceq.lol}"
export CEQ_STUDIO_URL="${CEQ_STUDIO_URL:-https://ceq.lol}"

# Required for authenticated checks
export CEQ_AUTH_TOKEN=""
export CEQ_ADMIN_AUTH_TOKEN="${CEQ_ADMIN_AUTH_TOKEN:-$CEQ_AUTH_TOKEN}"

# Golden-path GPU smoke — FLUX SCHNELL (fast, 16GB VRAM)
export CEQ_TEMPLATE_ID="d8b30c7e-4501-493f-94c7-5223d7777afb"
export CEQ_TEMPLATE_PARAMS_JSON='{"prompt":"golden path smoke","width":512,"height":512}'

# Quality image smoke — FLUX.1 DEV
# export CEQ_TEMPLATE_ID="94df20ca-280f-43a1-baa9-1c8b3f4eae48"
# export CEQ_TEMPLATE_PARAMS_JSON='{"prompt":"quality smoke","width":768,"height":768}'

# Strict smoke flags (set by post-deploy-verify.sh --strict)
# export CEQ_STRICT_SMOKE=true
# export CEQ_RUN_OPERATIONS_STATUS=true
# export CEQ_REQUIRE_OPERATIONS_STATUS=true
# export CEQ_REQUIRE_TEMPLATE_SEEDING=true
# export CEQ_REQUIRE_CREDITS_ROUTE=true

# GPU smoke timing
export CEQ_POLL_TIMEOUT_SECONDS="${CEQ_POLL_TIMEOUT_SECONDS:-600}"
export CEQ_POLL_INTERVAL_SECONDS="${CEQ_POLL_INTERVAL_SECONDS:-5}"
