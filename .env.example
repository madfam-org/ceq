# CEQ Environment Configuration
#
# SECURITY WARNING: This is a template file. DO NOT use these values in production!
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Generate secure secrets (see instructions below)
# 3. Fill in your actual credentials
# 4. Never commit .env file to version control
#
# CEQ has three services (api, studio, workers) that share some variables.
# Each service also has its own .env in apps/<service>/.env

# ============================================
# Environment
# ============================================

ENVIRONMENT=development
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# API Service (FastAPI - Port 5800)
# ============================================

HOST=0.0.0.0
PORT=5800
WORKERS=1
APP_NAME=ceq-api
APP_VERSION=0.1.0

# ============================================
# Database (PostgreSQL + asyncpg)
# ============================================

# Format: postgresql+asyncpg://username:password@host:port/database
# IMPORTANT: Change the password! Do not use default credentials
DATABASE_URL=postgresql+asyncpg://ceq:CHANGE_THIS_PASSWORD@localhost:5432/ceq_dev

# ============================================
# Redis (DB 14 per PORT_ALLOCATION.md)
# ============================================

REDIS_URL=redis://localhost:6379/14

# ============================================
# Janua OIDC Authentication
# ============================================

JANUA_ENABLED=false
JANUA_API_URL=http://localhost:4100
JANUA_JWKS_URL=https://auth.madfam.io/.well-known/jwks.json
JANUA_ISSUER=https://auth.madfam.io
JANUA_AUDIENCE=ceq

# Janua OAuth Client (server-side token exchange)
# JANUA_CLIENT_SECRET is used by the studio's server-side auth routes
# and must NOT be prefixed with NEXT_PUBLIC_
JANUA_CLIENT_SECRET=<your-janua-client-secret>

# ============================================
# Cloudflare R2 Storage
# ============================================

# Asset and output storage for generated content
R2_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=<your-r2-access-key>
R2_SECRET_KEY=<your-r2-secret-key>
R2_BUCKET=ceq-assets
R2_PUBLIC_URL=

# ============================================
# Studio Frontend (Next.js - Port 5801)
# ============================================

# Public variables (exposed to browser - prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:5800
NEXT_PUBLIC_WS_URL=ws://localhost:5820
NEXT_PUBLIC_JANUA_URL=https://auth.madfam.io
NEXT_PUBLIC_JANUA_CLIENT_ID=ceq-studio

# ============================================
# GPU Compute Providers
# ============================================

# Primary provider: vast | fal | furnace
CEQ_GPU_PROVIDER=vast
# CEQ_FALLBACK_PROVIDER=fal

# Vast.ai Configuration (instance-based, Docker deployment)
VAST_API_KEY=<your-vast-api-key>
VAST_REGION=any
VAST_SSH_KEY=~/.ssh/id_rsa
VAST_DEFAULT_IMAGE=ceq/worker:latest
VAST_MAX_PRICE=1.0
VAST_MAX_INSTANCES=5
VAST_SCALE_TO_ZERO=true
VAST_IDLE_TIMEOUT=300

# fal.ai Configuration (serverless API, per-request billing)
# FAL_API_KEY=<your-fal-api-key>
# FAL_MAX_HOURLY_SPEND=5.0

# Furnace Configuration (Enclii internal - future)
FURNACE_API_URL=http://localhost:4210
FURNACE_API_KEY=
# FURNACE_REGION=hetzner-fsn1
# FURNACE_SSH_KEY=~/.ssh/id_rsa
# FURNACE_DEFAULT_IMAGE=ghcr.io/madfam/ceq-worker:latest
# FURNACE_MAX_PRICE=0.50
# FURNACE_MAX_INSTANCES=10
# FURNACE_SCALE_TO_ZERO=true
# FURNACE_IDLE_TIMEOUT=300

# ============================================
# Worker Orchestrator
# ============================================

CEQ_MIN_WORKERS=0
CEQ_MAX_WORKERS=5
CEQ_TARGET_QUEUE=3
CEQ_SCALE_UP_THRESHOLD=5
CEQ_SCALE_DOWN_THRESHOLD=0
CEQ_IDLE_TIMEOUT=300
CEQ_HEALTH_INTERVAL=30
CEQ_SCALE_INTERVAL=10
CEQ_MIN_VRAM_GB=16.0
CEQ_MAX_HOURLY_SPEND=5.0
CEQ_WORKER_IMAGE=ceq/worker:latest

# ============================================
# ComfyUI Worker Settings
# ============================================

COMFYUI_DEFAULT_TIMEOUT=300
COMFYUI_MAX_CONCURRENT_JOBS=10

# Worker identity and paths (usually set per-worker, not in root .env)
# WORKER_ID=ceq-worker-1
# COMFYUI_PATH=/opt/comfyui
# MODELS_PATH=/opt/models
# OUTPUTS_PATH=/opt/outputs
# GPU_DEVICE=cuda:0
# VRAM_LIMIT_GB=20.0

# ============================================
# Rate Limiting
# ============================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOADS=10/minute
RATE_LIMIT_JOBS=30/minute

# ============================================
# Security
# ============================================

MAX_REQUEST_SIZE_MB=1
MAX_UPLOAD_SIZE_MB=100
PRESIGNED_URL_EXPIRY_SECONDS=3600

# ============================================
# CORS Configuration
# ============================================

# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5801","https://ceq.lol"]

# ============================================
# Monitoring & Observability (Optional)
# ============================================

# Sentry Error Tracking
# SENTRY_DSN=https://<key>@<project>.ingest.sentry.io/<id>
# SENTRY_ENVIRONMENT=development

# ============================================
# Quick Start for Development
# ============================================
#
# To get started quickly:
#
# 1. Start infrastructure:
#    docker compose up -d postgres redis
#
# 2. Run the API:
#    cd apps/api && source .venv/bin/activate
#    uvicorn ceq_api.main:app --port 5800 --reload
#
# 3. Run the studio:
#    pnpm --filter @ceq/studio dev
#
# 4. (Optional) Run a GPU worker:
#    Set VAST_API_KEY, then:
#    cd apps/workers && python -m ceq_worker.orchestrator
#
# Port Allocation (5800-5899 block):
#   API:        5800
#   Studio:     5801
#   WebSocket:  5820
#   Workers:    5810-5819
