# CEQ Worker Slim - Minimal ComfyUI Worker
#
# A smaller image without custom nodes for faster deployments.
# Use when you only need core SDXL/Flux workflows.
#
# Size: ~8GB (vs ~15GB for full image)
# Build: docker build -f Dockerfile.slim -t ceq-worker:slim .

FROM nvidia/cuda:12.4.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

# Minimal system deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11 \
    python3.11-venv \
    python3-pip \
    git \
    wget \
    curl \
    ffmpeg \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 && \
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# Clone ComfyUI
RUN git clone --depth 1 https://github.com/comfyanonymous/ComfyUI.git /opt/comfyui

WORKDIR /opt/comfyui

# Install minimal dependencies
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu124 && \
    pip install --no-cache-dir -r requirements.txt

# Only install ComfyUI-Manager for extension management
RUN mkdir -p custom_nodes && \
    cd custom_nodes && \
    git clone --depth 1 https://github.com/ltdrdata/ComfyUI-Manager.git && \
    pip install --no-cache-dir -r ComfyUI-Manager/requirements.txt || true

# Create directories
RUN mkdir -p /opt/models /opt/outputs /opt/cache

# Copy and install CEQ worker
COPY . /app/ceq-worker
WORKDIR /app/ceq-worker
RUN pip install --no-cache-dir -e .

# Model paths config
RUN cat > /opt/comfyui/extra_model_paths.yaml <<EOF
ceq_models:
    base_path: /opt/models
    checkpoints: checkpoints
    loras: loras
    vae: vae
    controlnet: controlnet
    embeddings: embeddings
    upscale_models: upscale_models
EOF

# Environment
ENV COMFYUI_PATH=/opt/comfyui
ENV MODELS_PATH=/opt/models
ENV OUTPUTS_PATH=/opt/outputs

EXPOSE 8188

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD curl -sf http://localhost:8188/system_stats || exit 1

VOLUME ["/opt/models", "/opt/outputs"]


# Audit 2026-04-23 (cross-cutting I.1): run as non-root `ceq`.
# ComfyUI + CUDA both work as non-root on nvidia-container-toolkit-managed
# GPU nodes (standard in our k3s cluster). Override with `--user 0` at
# runtime if a Vast.ai target needs root.
RUN useradd -r -u 10001 -m -s /bin/bash ceq \
    && chown -R ceq:ceq /opt/comfyui /opt/models /opt/outputs /opt/cache /app/ceq-worker
USER ceq

CMD ["python", "-m", "ceq_worker.queue"]
