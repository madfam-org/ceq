# CEQ API Environment Configuration
# Copy to .env and fill in real values

# ============================================
# Application
# ============================================
APP_NAME=ceq-api
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ============================================
# Server
# ============================================
HOST=0.0.0.0
PORT=5800
WORKERS=1

# ============================================
# Database (PostgreSQL + asyncpg)
# ============================================
DATABASE_URL=postgresql+asyncpg://ceq:ceq_dev@localhost:5432/ceq_dev

# ============================================
# Redis (DB 14 per PORT_ALLOCATION.md)
# ============================================
REDIS_URL=redis://localhost:6379/14

# ============================================
# Janua OIDC Authentication
# ============================================
JANUA_JWKS_URL=https://auth.madfam.io/.well-known/jwks.json
JANUA_ISSUER=https://auth.madfam.io
JANUA_AUDIENCE=ceq
JANUA_API_URL=http://localhost:4100
JANUA_ENABLED=false

# ============================================
# Furnace (GPU Compute)
# ============================================
FURNACE_API_URL=http://localhost:4210
FURNACE_API_KEY=

# ============================================
# Cloudflare R2 Storage
# ============================================
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=ceq-assets
R2_PUBLIC_URL=

# ============================================
# ComfyUI Worker Settings
# ============================================
COMFYUI_DEFAULT_TIMEOUT=300
COMFYUI_MAX_CONCURRENT_JOBS=10

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_UPLOADS=10/minute
RATE_LIMIT_JOBS=30/minute

# ============================================
# Security
# ============================================
MAX_REQUEST_SIZE_MB=1
MAX_UPLOAD_SIZE_MB=100
PRESIGNED_URL_EXPIRY_SECONDS=3600

# ============================================
# CORS
# ============================================
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5801","https://ceq.lol"]
